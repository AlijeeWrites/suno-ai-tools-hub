{
  "toolId": "suno-prompt-generator",
  "title": "Suno Prompt Generator",
  "description": "Generate professional Suno AI music prompts with customizable parameters for better AI-generated songs.",
  "fields": [
    {
      "id": "genre",
      "label": "Music Genre",
      "type": "select",
      "options": ["Pop", "Rock", "Hip Hop", "Electronic", "Jazz", "Classical", "Country", "R&B", "Metal", "Folk", "Lo-fi", "Synthwave"],
      "required": true
    },
    {
      "id": "mood",
      "label": "Mood/Vibe",
      "type": "select",
      "options": ["Energetic", "Chill", "Melancholic", "Romantic", "Epic", "Dark", "Uplifting", "Mysterious", "Nostalgic", "Aggressive"],
      "required": true
    },
    {
      "id": "vocal_type",
      "label": "Vocal Type",
      "type": "select",
      "options": ["Female Vocals", "Male Vocals", "Duet", "Instrumental Only", "Choir", "Rap Vocals"],
      "required": false
    },
    {
      "id": "instruments",
      "label": "Main Instrument(s)",
      "type": "select",
      "options": ["Bass", "Guitar", "Piano", "Drums", "Synth", "Strings", "Brass", "Full Band", "Acoustic"],
      "required": true
    },
    {
      "id": "tempo",
      "label": "Tempo (BPM)",
      "type": "range",
      "min": 60,
      "max": 200,
      "default": 120
    },
    {
      "id": "structure",
      "label": "Song Structure",
      "type": "select",
      "options": ["Verse-Chorus", "Full Song", "Intro Only", "Loop / Beat", "Cinematic Build"],
      "required": false
    },
    {
      "id": "style_notes",
      "label": "Additional Style Notes",
      "type": "textarea",
      "placeholder": "e.g. female vocals, emotional chorus, cinematic intro, trap drums, atmospheric production"
    }
  ],
  "template": "{mood} {genre}, {tempo} BPM, {instruments}. {vocal_type}. {structure}. {style_notes}. Polished studio-quality mix, modern production, high fidelity.",
  "monetization": {
    "donationLink": "https://sevensky.gumroad.com/coffee",
    "productLink": "https://sevensky.gumroad.com",
    "productText": "Get 15,000+ Suno AI Prompts Library (200+ Genres)"
  }
}
